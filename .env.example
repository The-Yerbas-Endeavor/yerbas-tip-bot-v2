NODE_ENV=development
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
BOT_CHANNEL_ID=
ADMIN_ROLE_ID=
BOT_STATUS=Yerbas Tip Bot v2
LOG_LEVEL=info

# Existing legacy tip-bot database.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=yerbas_tip_bot
MYSQL_PASSWORD=
MYSQL_DATABASE=yerbas_tip_bot
MYSQL_CONNECTION_LIMIT=10

YERBAS_RPC_URL=http://127.0.0.1:9998
YERBAS_RPC_USER=
YERBAS_RPC_PASSWORD=
YERBAS_RPC_TIMEOUT_MS=15000

DEPOSIT_CONFIRMATIONS=6
MINIMUM_TIP_YERB=0.01
MINIMUM_WITHDRAWAL_YERB=1
WITHDRAWAL_FEE_YERB=0.01

# Leave all financial switches false until tested against a restored database copy.
WALLET_ENABLED=false
WITHDRAWALS_ENABLED=false
ASSETS_ENABLED=false
ASSET_WITHDRAWALS_ENABLED=false

NODE_ENV=development
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
BOT_CHANNEL_ID=
ADMIN_ROLE_ID=
BOT_STATUS=Yerbas Tip Bot v2
